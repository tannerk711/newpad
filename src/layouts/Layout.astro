---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'New Construction Homes & Duplexes – Fort Worth, Texas | NewPad Building Co',
  description = 'New construction homes and duplexes in Fort Worth starting at $254K. Quality builds with a personal touch from NewPad Building Co. Browse available homes today.',
} = Astro.props;

const siteUrl = 'https://newpadbuilding.com';
const ogImageUrl = `${siteUrl}/og-image.jpg`;
const canonicalUrl = siteUrl;

// JSON-LD structured data for HomeBuilder
const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'HomeBuilder',
  name: 'NewPad Building Co',
  description: 'New construction homes and duplexes in Fort Worth, Texas. Starting at $254K.',
  url: siteUrl,
  telephone: '+1-817-632-6122',
  email: 'ridg@congergroup.com',
  founder: {
    '@type': 'Person',
    name: 'Cooper Conger',
  },
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'Fort Worth',
    addressRegion: 'TX',
    addressCountry: 'US',
  },
  areaServed: {
    '@type': 'City',
    name: 'Fort Worth',
  },
  priceRange: '$254K - $509K',
  image: ogImageUrl,
};
---

<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <meta name="author" content="NewPad Building Co" />

    <!-- Canonical -->
    <link rel="canonical" href={canonicalUrl} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />

    <!-- Preconnect for Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

    <!-- Google Fonts - loaded async to avoid render-blocking -->
    <link
      rel="preload"
      as="style"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
      media="print"
      onload="this.media='all'"
    />
    <noscript>
      <link
        href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
        rel="stylesheet"
      />
    </noscript>

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="NewPad Building Co" />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <!-- Structured Data (JSON-LD) -->
    <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />

    <title>{title}</title>
  </head>
  <body class="min-h-screen bg-white text-forest antialiased">
    <slot />
  </body>
</html>
