---
import { testimonials } from '../data/testimonials';
---

<section id="testimonials" class="bg-sage-light py-16 md:py-24">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-3xl text-center">
      <h2 data-gsap="heading" class="text-3xl font-bold tracking-tight text-forest md:text-4xl">
        Real Stories From Real Homeowners
      </h2>
      <p data-gsap="subhead" class="mt-4 text-lg text-gray-500">
        Here's what buyers say about working with Cooper and the NewPad team.
      </p>
    </div>

    <div class="mt-12 grid gap-6 md:grid-cols-3">
      {testimonials.map((testimonial) => (
        <div data-gsap="card" class="flex flex-col rounded-2xl bg-white p-4 shadow-md transition-shadow hover:shadow-lg sm:p-6 md:p-8">
          <!-- Stars -->
          <div class="mb-4 flex gap-1">
            {[1, 2, 3, 4, 5].map(() => (
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="h-5 w-5 text-gold">
                <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" />
              </svg>
            ))}
          </div>

          <!-- Highlight quote -->
          <p class="mb-3 text-base font-semibold italic text-forest sm:text-lg">
            "{testimonial.highlight}"
          </p>

          <!-- Full quote -->
          <p class="flex-1 text-sm leading-relaxed text-gray-500">
            "{testimonial.quote}"
          </p>

          <!-- Attribution -->
          <div class="mt-6 flex items-center gap-3 border-t border-gray-200 pt-4">
            <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-sage text-sm font-bold text-forest">
              {testimonial.name.charAt(0)}
            </div>
            <div>
              <p class="font-semibold text-forest">{testimonial.name}</p>
              <p class="text-xs text-gray-400">{testimonial.label}</p>
            </div>
          </div>
        </div>
      ))}
    </div>

    <div data-gsap="cta" class="mt-10 text-center">
      <a
        href="#lead-form"
        class="inline-flex items-center gap-2 rounded-xl bg-forest px-6 py-3 text-base font-semibold text-off-white transition-all hover:bg-forest-light hover:shadow-lg"
      >
        Talk to a NewPad Expert
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="h-4 w-4">
          <path d="M5 12h14" /><path d="m12 5 7 7-7 7" />
        </svg>
      </a>
    </div>
  </div>
</section>
