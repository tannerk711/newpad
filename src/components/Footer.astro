---
const currentYear = new Date().getFullYear();
---

<footer class="border-t border-gray-200 bg-white py-8 md:py-10">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="grid gap-8 md:grid-cols-3 md:items-center">
      <!-- Logo / Company -->
      <div>
        <a href="#hero" class="inline-flex items-center">
          <img src="/newpad-logo.svg" alt="NewPad Building Co" class="h-7 w-auto" />
        </a>
        <p class="mt-2 text-xs leading-relaxed text-gray-400">
          New construction homes and duplexes in Fort Worth, Texas. Built by Cooper Conger and the NewPad team.
        </p>
      </div>

      <!-- Contact -->
      <div class="flex flex-col items-start gap-2 text-sm text-gray-500 md:items-center">
        <a href="tel:+12088660166" class="flex items-center gap-2 transition-colors hover:text-forest">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="h-4 w-4">
            <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z" />
          </svg>
          (208) 866-0166
        </a>
        <a href="mailto:cconger@congergroup.com" class="flex items-center gap-2 transition-colors hover:text-forest">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="h-4 w-4">
            <rect x="2" y="4" width="20" height="16" rx="2" /><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7" />
          </svg>
          cconger@congergroup.com
        </a>
      </div>

      <!-- Legal -->
      <div class="flex flex-col items-start gap-2 text-xs text-gray-400 md:items-end">
        <a href="https://www.newpadbuildingco.com/legal/privacy-policy" target="_blank" rel="noopener noreferrer" class="transition-colors hover:text-forest">Privacy Policy</a>
        <a href="https://www.newpadbuildingco.com/legal/terms-of-service" target="_blank" rel="noopener noreferrer" class="transition-colors hover:text-forest">Terms of Service</a>
      </div>
    </div>

    <div class="mt-8 border-t border-gray-200 pt-6 text-center text-xs text-gray-400">
      &copy; {currentYear} NewPad Building Co. All rights reserved. Fort Worth, Texas.
    </div>
  </div>
</footer>
