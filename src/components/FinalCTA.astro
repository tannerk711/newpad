---
// Final CTA: dark forest section, strong push to fill out the form
---

<section id="final-cta" class="bg-forest py-16 md:py-24">
  <div class="mx-auto max-w-3xl px-4 text-center sm:px-6 lg:px-8">
    <h2 data-gsap="heading" class="text-2xl font-bold tracking-tight text-white sm:text-3xl md:text-4xl">
      Your Next Home Starts Here
    </h2>
    <p data-gsap="subhead" class="mt-4 text-lg leading-relaxed text-sage-dark">
      Tell Cooper what you're looking for. New home or duplex, budget and timeline. We'll send matches fast. No pressure, just clear options.
    </p>
    <div data-gsap="button" class="mt-8">
      <a
        href="#lead-form"
        class="inline-flex items-center gap-2 rounded-xl bg-green-accent px-8 py-4 text-lg font-bold text-forest transition-all hover:bg-sage hover:shadow-xl"
      >
        Get My Matches
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="h-5 w-5">
          <path d="M5 12h14" /><path d="m12 5 7 7-7 7" />
        </svg>
      </a>
    </div>

    <!-- Trust signals -->
    <div data-gsap="trust" class="mt-10 flex flex-wrap items-center justify-center gap-3 text-sm text-sage-dark sm:gap-6">
      <div class="flex items-center gap-2">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="h-4 w-4">
          <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" />
        </svg>
        1-2-6 Warranty
      </div>
      <div class="flex items-center gap-2">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="h-4 w-4">
          <rect x="1" y="4" width="22" height="16" rx="2" ry="2" /><line x1="1" y1="10" x2="23" y2="10" />
        </svg>
        $10K Builder Incentive
      </div>
      <div class="flex items-center gap-2">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="h-4 w-4">
          <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14" /><polyline points="22 4 12 14.01 9 11.01" />
        </svg>
        Homes Available Now
      </div>
    </div>
  </div>
</section>
